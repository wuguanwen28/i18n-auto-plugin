{
  "name": "i18n-auto-plugin",
  "version": "0.0.7",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js",
      "require": "./dist/cjs/vite-plugin.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack-plugin.d.ts",
      "import": "./dist/webpack-plugin.js",
      "require": "./dist/cjs/webpack-plugin.cjs"
    }
  },
  "bin": {
    "i18n": "./bin/index.js"
  },
  "scripts": {
    "dev": "premove dist && pnpm build-bundle -w",
    "build": "premove dist && pnpm build-bundle",
    "build-bundle": "rolldown -c rolldown.config.ts"
  },
  "keywords": [
    "i18n",
    "vue-i18n",
    "react-i18n",
    "translate",
    "auto-translate",
    "翻译",
    "国际化",
    "自动翻译"
  ],
  "author": "wuguanwen",
  "repository": {
    "type": "git",
    "url": "https://github.com/wuguanwen28/i18n-auto-react.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@babel/helper-module-imports": "^7.28.6",
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "@vue/compiler-core": "^3.5.27",
    "@vue/compiler-sfc": "^3.5.27",
    "cac": "^6.7.14",
    "chalk": "^5.6.2",
    "cosmiconfig": "^9.0.0",
    "ignore": "^7.0.5",
    "magic-string": "^1.0.0",
    "prettier": "^3.8.0",
    "unplugin": "^3.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__helper-module-imports": "^7.18.3",
    "@types/babel__traverse": "^7.28.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^16.18.126",
    "premove": "^4.0.0",
    "rolldown": "1.0.0-beta.60",
    "rolldown-plugin-dts": "^0.21.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "webpack": "^5.104.1"
  }
}
